---
interface Props { 
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <style is:global>
        :root { 
            /* Obsidian System Variables */
            --primary: #06B6D4; /* Pulse Teal */
            --text: #ffffff;    
            --bg: #0A0A0A;      /* Obsidian Black */
            --card-bg: #111111; /* Slightly lighter black for cards */
            --surgical: #27272a; /* Sharp UI borders */
        }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
            background: var(--bg); 
            color: var(--text); 
            margin: 0; 
            line-height: 1.5; 
        }
        nav { 
            background: var(--bg); 
            border-bottom: 1px solid var(--surgical); 
            padding: 1.25rem 2rem; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            position: sticky; 
            top: 0; 
            z-index: 50;
        }
        .nav-logo { 
            font-weight: 900; 
            font-size: 1.25rem; 
            text-decoration: none; 
            color: white; 
            display: flex; 
            align-items: center; 
            gap: 6px; 
            letter-spacing: -0.04em;
        }
        .nav-links { 
            display: flex; 
            align-items: center; 
            gap: 2rem; 
        }
        .nav-links > a:not(.cta-btn) { 
            text-decoration: none; 
            color: #a1a1aa; 
            font-size: 0.75rem; 
            font-family: monospace;
            font-weight: 700; 
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: color 0.2s ease; 
        }
        .nav-links > a:not(.cta-btn):hover { 
            color: white; 
        }
        .cta-btn { 
            background: var(--primary); 
            color: #000000 !important; 
            padding: 0.75rem 1.5rem; 
            border-radius: 4px; 
            font-family: monospace;
            font-size: 0.75rem;
            font-weight: 800; 
            text-transform: uppercase;
            letter-spacing: 0.1em;
            text-decoration: none;
            transition: all 0.2s ease;
        }
        .cta-btn:hover { 
            background: #22d3ee; /* Lighter cyan on hover */
        }
        
        /* Global Fallback Styles (Used if not overridden in individual pages) */
        main { max-width: 900px; margin: 4rem auto; padding: 0 2rem; }
        h1 { font-size: 3rem; font-weight: 800; letter-spacing: -0.025em; margin-bottom: 1rem; color: white; }
        .hero-sub { font-size: 1.25rem; color: #a1a1aa; margin-bottom: 4rem; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
        @media (max-width: 768px) { .grid { grid-template-columns: 1fr; } }
        
        .card { 
            background: var(--card-bg); 
            border: 1px solid var(--surgical); 
            padding: 2rem; 
            border-radius: 8px; 
            text-decoration: none; 
            transition: all 0.2s ease; 
            display: flex; 
            flex-direction: column; 
        }
        .card:hover { border-color: var(--primary); }
        .card-tag { 
            font-family: monospace;
            font-size: 0.65rem; 
            font-weight: 700; 
            color: var(--primary); 
            text-transform: uppercase; 
            letter-spacing: 0.1em;
            margin-bottom: 0.5rem; 
            padding: 0.2rem 0.5rem;
            border: 1px solid rgba(6, 182, 212, 0.2);
            background: rgba(6, 182, 212, 0.1);
            border-radius: 4px;
            width: fit-content;
        }
        .card-title { font-size: 1.5rem; font-weight: 800; margin: 0.5rem 0; color: white; line-height: 1.2; letter-spacing: -0.02em; }
        .card-date { font-family: monospace; font-size: 0.75rem; color: #71717a; text-transform: uppercase; letter-spacing: 0.05em; }
        .card-link { 
            margin-top: 1.5rem; 
            font-family: monospace;
            font-size: 0.75rem; 
            font-weight: 800; 
            color: var(--primary); 
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
    </style>
</head>
<body>
    <nav>
        <a href="/" class="nav-logo">
            ConversionDoc
            <svg width="46" height="24" viewBox="0 0 46 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 2px;">
                <path d="M 2 12 L 8 12 L 12 16 L 18 4 L 24 20 L 28 12 L 34 12 L 42 4" />
                <polyline points="35 4 42 4 42 11" />
            </svg>
        </a>
        <div class="nav-links">
            <a href="/">Transmission_Log</a>
            <a href="https://conversiondoc.co.uk" class="cta-btn">Get Free Audit</a>
        </div>
    </nav>
    <slot />
</body>
</html>
