---
interface Props {
	title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<script src="https://cdn.tailwindcss.com"></script>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
		<style>
			body { font-family: 'Inter', sans-serif; background-color: #f9fafb; }
		</style>
	</head>
	<body class="text-slate-900">
		<nav class="bg-white border-b sticky top-0 z-50">
			<div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href="/" class="text-xl font-bold tracking-tight hover:text-blue-600 transition">ConversionDoc</a>
				<div class="flex gap-6 text-sm font-medium">
					<a href="/" class="hover:text-blue-600">Blog</a>
					<a href="/studio" class="bg-slate-900 text-white px-4 py-2 rounded-lg hover:bg-slate-800 transition">Writing Desk</a>
				</div>
			</div>
		</nav>
		<slot />
		<footer class="mt-20 py-10 border-t bg-white">
			<div class="max-w-5xl mx-auto px-6 text-center text-slate-500 text-sm">
				© 2026 ConversionDoc. Built with precision.
			</div>
		</footer>
	</body>
</html>
