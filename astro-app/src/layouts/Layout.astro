---
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
        
        /* 1. CHANGE YOUR MAIN BRAND COLORS HERE */
        :root { 
            --primary: #2563eb; /* Change this hex to your brand color (currently blue) */
            --text: #1f2937;    /* Main text color (currently dark gray) */
            --bg: #f9fafb;      /* Background color (currently off-white) */
        }

        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); margin: 0; line-height: 1.5; }
        nav { background: white; border-bottom: 1px solid #e5e7eb; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; }
        .nav-logo { font-weight: 800; font-size: 1.25rem; text-decoration: none; color: black; }
        .nav-links a { text-decoration: none; color: #4b5563; margin-left: 1.5rem; font-size: 0.875rem; font-weight: 500; }
        
        /* 2. CHANGE THE "WRITING DESK" BUTTON COLOR HERE */
        .btn { background: #111827; color: white !important; padding: 0.5rem 1rem; border-radius: 0.5rem; }
        
        main { max-width: 900px; margin: 4rem auto; padding: 0 2rem; }
        h1 { font-size: 3rem; font-weight: 800; letter-spacing: -0.025em; margin-bottom: 1rem; color: #111827; }
        .hero-sub { font-size: 1.25rem; color: #4b5563; margin-bottom: 4rem; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
        @media (max-width: 768px) { .grid { grid-template-columns: 1fr; } }
        .card { background: white; border: 1px solid #e5e7eb; padding: 2rem; border-radius: 1rem; text-decoration: none; transition: all 0.2s; display: flex; flex-direction: column; }
        .card:hover { border-color: var(--primary); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
        .card-tag { font-size: 0.75rem; font-weight: 700; color: var(--primary); text-transform: uppercase; margin-bottom: 0.5rem; }
        .card-title { font-size: 1.5rem; font-weight: 700; margin: 0.5rem 0; color: #111827; }
        .card-date { font-size: 0.875rem; color: #9ca3af; }
        .card-link { margin-top: 1.5rem; font-weight: 600; color: var(--primary); }
    </style>
</head>
<body>
    <nav>
        <a href="/" class="nav-logo">ConversionDoc</a>
        <div class="nav-links">
            <a href="/">Blog</a>
            <a href="/studio" class="btn">Writing Desk</a>
        </div>
    </nav>
    <slot />
</body>
</html>
