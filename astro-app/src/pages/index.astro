---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from "sanity:client";
const posts = await sanityClient.fetch(`*[_type == "post"] | order(publishedAt desc)`);
---
<Layout title="ConversionDoc | Blog">
    <main>
        <header>
            <h1>Inside ConversionDoc</h1>
            <p class="hero-sub">Strategic thoughts on marketing, conversion, and growth.</p>
        </header>
        <div class="grid">
            {posts && posts.length > 0 ? (
                posts.map((post: any) => (
                    <a href={`/post/${post.slug.current}`} class="card">
                        <span class="card-tag">Article</span>
                        <h2 class="card-title">{post.title}</h2>
                        <span class="card-date">{post.publishedAt ? new Date(post.publishedAt).toLocaleDateString() : 'Just Published'}</span>
                        <span class="card-link">Read Article →</span>
                    </a>
                ))
            ) : (
                <p>No posts found. Start writing in the desk!</p>
            )}
        </div>
    </main>
</Layout> 
