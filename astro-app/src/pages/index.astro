---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from "sanity:client";

// This tells the site: "Go get my posts from Sanity"
const posts = await sanityClient.fetch(`*[_type == "post"] | order(publishedAt desc)`);
---

<Layout title="ConversionDoc Blog">
	<main class="max-w-4xl mx-auto p-6">
		<h1 class="text-4xl font-bold mb-12 text-center border-b pb-6">ConversionDoc Blog</h1>
		
		<div class="grid gap-8">
			{posts.length > 0 ? (
				posts.map((post) => (
					<article class="p-6 border rounded-xl shadow-sm hover:shadow-md transition bg-white">
						<h2 class="text-2xl font-semibold mb-3">
							<a href={`/post/${post.slug.current}`} class="text-blue-600 hover:text-blue-800">
								{post.title}
							</a>
						</h2>
						<p class="text-gray-400 text-sm italic">
							{post.publishedAt ? new Date(post.publishedAt).toLocaleDateString() : 'Published recently'}
						</p>
					</article>
				))
			) : (
				<div class="text-center py-20 bg-gray-50 rounded-lg border-2 border-dashed">
					<p class="text-xl text-gray-500 mb-4">No posts found.</p>
					<p class="text-gray-400 text-sm">
						If you see this, check your <a href="/studio" class="text-blue-500 underline">Studio</a> 
						to make sure your post is actually <b>Published</b> (Green), not just a Draft.
					</p>
				</div>
			)}
		</div>
	</main>
</Layout>
