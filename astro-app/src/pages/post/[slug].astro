---
import Layout from "../../layouts/Layout.astro";
import { sanityClient } from "sanity:client";
import { PortableText } from "astro-portabletext";

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "post"]{
    _id,
    title,
    slug,
    publishedAt,
    body[]{
      ...,
      _type == "image" => {
        "_type": "image",
        "url": asset->url,
        "alt": alt
      }
    }
  }`);
  return posts.map((post: any) => ({
    params: { slug: post.slug.current },
    props: { post },
  }));
}

const { post }: any = Astro.props;
---

<Layout title={post.title}>
  <style is:inline>
    .article-container { 
        max-width: 750px; 
        margin: 4rem auto; 
        padding: 0 2rem; 
    }
    .post-title { 
        font-size: 3.5rem; 
        font-weight: 800; 
        color: #ffffff !important; 
        letter-spacing: -0.04em; 
        line-height: 1.1; 
        margin-bottom: 1.5rem; 
    }
    .post-meta { 
        color: #94a3b8 !important; 
        font-size: 1rem; 
        margin-bottom: 3rem; 
        display: block; 
    }
    .content { 
        font-size: 1.25rem; 
        line-height: 1.8; 
        color: #e2e8f0 !important; 
    }
    .content p { 
        margin-bottom: 1.8rem; 
        color: #e2e8f0 !important; 
    }
    .content h1, .content h2, .content h3 { 
        color: #ffffff !important; 
        margin-top: 3rem; 
    }
    .content img {
        max-width: 100%;
        margin: 2rem 0;
        border-radius: 8px;
    }
    .back-link { 
        display: inline-block; 
        margin-top: 5rem; 
        padding-top: 2rem; 
        border-top: 1px solid rgba(255,255,255,0.1); 
        width: 100%; 
        color: #14b885 !important; 
        font-weight: 600; 
        text-decoration: none; 
    }
    .back-link:hover { 
        text-decoration: underline; 
    }
  </style>

  <main class="article-container">
    <header>
      <h1 class="post-title">{post.title}</h1>
      <time class="post-meta">
        {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : 'Published recently'}
      </time>
    </header>
    
    <div class="content">
      {post.body && post.body.map((block: any) => {
        if (block._type === 'image' && block.url) {
          return <img src={block.url} alt={block.alt || ''} style="max-width:100%;margin:2rem 0;border-radius:8px;" />
        }
        return null;
      })}
      <PortableText value={post.body} />
    </div>

    <a href="/" class="back-link">← Back to all insights</a>
  </main>
</Layout>
