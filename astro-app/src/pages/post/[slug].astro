---
import Layout from "../../layouts/Layout.astro";
import { sanityClient } from "sanity:client";
import { PortableText } from "astro-portabletext";
import Callout from "../../components/Callout.astro"; 

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "post"]{
    _id,
    title,
    slug,
    publishedAt,
    metaDescription,
    body[]{
      ...,
      _type == "image" => {
        "_type": "image",
        "url": asset->url,
        "alt": alt
      }
    }
  }`);
  return posts.map((post: any) => ({
    params: { slug: post.slug.current },
    props: { post },
  }));
}

const { post }: any = Astro.props;

const bodySegments: any[] = [];
let currentTextBlocks: any[] = [];

for (const block of post.body || []) {
  if (block._type === 'image') {
    if (currentTextBlocks.length > 0) {
      bodySegments.push({ type: 'text', blocks: currentTextBlocks });
      currentTextBlocks = [];
    }
    bodySegments.push({ type: 'image', block });
  } else {
    currentTextBlocks.push(block);
  }
}
if (currentTextBlocks.length > 0) {
  bodySegments.push({ type: 'text', blocks: currentTextBlocks });
}
---

<Layout title={post.title} description={post.metaDescription || ''}>
  <style is:inline>
    body {
        background-color: #0A0A0A !important;
    }
    .article-container { 
        max-width: 700px; 
        margin: 6rem auto; 
        padding: 0 1.5rem; 
    }
    .post-header {
        border-bottom: 1px solid #27272a;
        padding-bottom: 2rem;
        margin-bottom: 3rem;
    }
    .post-title { 
        font-size: 3rem; 
        font-weight: 900; 
        color: #ffffff !important; 
        letter-spacing: -0.04em; 
        line-height: 1.1; 
        margin-bottom: 1.5rem; 
    }
    .post-meta { 
        color: #06B6D4 !important; 
        font-family: monospace;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-size: 0.75rem; 
        font-weight: bold;
        display: block; 
    }
    .content { 
        font-size: 1.15rem; 
        line-height: 1.8; 
        color: #a1a1aa !important; 
    }
    .content p { 
        margin-bottom: 2rem; 
        color: #a1a1aa !important; 
    }
    .content strong {
        color: #ffffff !important;
        font-weight: 700;
    }
    .content h1, .content h2, .content h3 { 
        color: #ffffff !important; 
        margin-top: 4rem; 
        margin-bottom: 1.5rem;
        font-weight: 800;
        letter-spacing: -0.02em;
    }
    .content h2 { font-size: 2rem; }
    .content h3 { font-size: 1.5rem; }
    
    .content ul, .content ol {
        margin-bottom: 2rem;
        padding-left: 1.5rem;
    }
    .content li {
        margin-bottom: 0.5rem;
        padding-left: 0.5rem;
    }
    .content li::marker {
        color: #06B6D4;
    }
    .content a {
        color: #06B6D4 !important;
        text-decoration: underline;
        text-decoration-color: rgba(6, 182, 212, 0.3);
        text-underline-offset: 4px;
        transition: all 0.2s ease;
    }
    .content a:visited {
        color: #06B6D4 !important;
    }
    .content a:hover {
        text-decoration-color: rgba(6, 182, 212, 1);
        background-color: rgba(6, 182, 212, 0.1);
    }
    .content blockquote {
        border-left: 4px solid #06B6D4;
        padding-left: 1.5rem;
        margin: 3rem 0;
        font-style: italic;
        color: #d4d4d8 !important;
        background: rgba(6, 182, 212, 0.05);
        padding: 1.5rem;
        border-radius: 0 8px 8px 0;
    }
    .article-image {
        width: 100%;
        margin: 3rem 0;
        border-radius: 8px;
        display: block;
        border: 1px solid #27272a;
    }
    .back-link { 
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 5rem; 
        padding-top: 2rem; 
        border-top: 1px solid #27272a; 
        width: 100%; 
        color: #71717a !important; 
        font-family: monospace;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: bold; 
        text-decoration: none;
        transition: color 0.2s ease;
    }
    .back-link:hover { 
        color: #ffffff !important;
    }
  </style>

  <main class="article-container">
    <header class="post-header">
      <time class="post-meta">
        TRANSMISSION_DATE: {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) : 'JUST_PUBLISHED'}
      </time>
      <h1 class="post-title">{post.title}</h1>
    </header>
    
    <div class="content">
      {bodySegments.map((segment) => {
        if (segment.type === 'image') {
          return <img src={segment.block.url} alt={segment.block.alt || ''} class="article-image" />
        }
        return (
          <PortableText 
            value={segment.blocks} 
            components={{
              type: {
                callout: Callout, 
              }
            }}
          />
        )
      })}
    </div>

    <a href="/" class="back-link">← Return to Index</a>
  </main>
</Layout>
