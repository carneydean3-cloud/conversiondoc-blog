---
import Layout from "../../layouts/Layout.astro";
import { sanityClient } from "sanity:client";
import { PortableText } from "astro-portabletext";

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "post"]`);
  return posts.map((post: any) => ({
    params: { slug: post.slug.current },
    props: { post },
  }));
}

const { post }: any = Astro.props;
---

<Layout title={post.title}>
  <style is:inline>
    .article-container { max-width: 750px; margin: 4rem auto; padding: 0 2rem; }
    .post-title { font-size: 3.5rem; font-weight: 800; color: #111827; letter-spacing: -0.04em; line-height: 1.1; margin-bottom: 1.5rem; }
    .post-meta { color: #6b7280; font-size: 1rem; margin-bottom: 3rem; display: block; font-weight: 500; }
    .content { font-size: 1.25rem; line-height: 1.7; color: #374151; }
    .content p { margin-bottom: 1.8rem; }
    .content h2 { font-size: 2rem; margin-top: 3rem; color: #111827; }
    .back-link { display: inline-block; margin-top: 5rem; padding-top: 2rem; border-top: 1px solid #e5e7eb; width: 100%; color: #2563eb; font-weight: 600; text-decoration: none; }
    .back-link:hover { text-decoration: underline; }
  </style>

  <main class="article-container">
    <header>
      <h1 class="post-title">{post.title}</h1>
      <time class="post-meta">
        {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : 'Published recently'}
      </time>
    </header>
    
    <div class="content">
      <PortableText value={post.body} />
    </div>

    <a href="/" class="back-link">← Back to all insights</a>
  </main>
</Layout>
