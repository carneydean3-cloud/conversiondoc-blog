---
import { PortableText } from 'astro-portabletext';

const { node } = Astro.props;

// 1. Safely grab the data from Sanity
const styleName = typeof node?.style === 'string' ? node.style : 'tldr';
const textContent = node?.text || [];

// 2. Foolproof if/else statement so TypeScript cannot fail the build
let displayLabel = "TL;DR / Summary";
if (styleName === 'action') {
  displayLabel = "Action Item";
} else if (styleName === 'warning') {
  displayLabel = "Important";
}
---

<div class={`custom-callout callout-${styleName}`}>
  <div class="callout-header">
    {displayLabel}
  </div>
  <div class="callout-body">
     <PortableText value={textContent} />
  </div>
</div>

<style>
  .custom-callout {
    margin: 2.5rem 0;
    padding: 1.5rem 2rem;
    border-left: 4px solid #3b82f6; /* Default Blue */
    background-color: rgba(59, 130, 246, 0.1);
    border-radius: 0 0.5rem 0.5rem 0;
  }
  .callout-action {
    border-left-color: #10b981; /* Green */
    background-color: rgba(16, 185, 129, 0.1);
  }
  .callout-warning {
    border-left-color: #f59e0b; /* Amber */
    background-color: rgba(245, 158, 11, 0.1);
  }
  .callout-header {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
    color: #ffffff;
    opacity: 0.9;
  }
  .callout-body {
    font-size: 1.15rem;
    line-height: 1.7;
    color: #e2e8f0;
  }
  /* Target the rich text coming from Sanity */
  .callout-body :global(ul) {
    list-style-type: disc;
    margin-left: 1.5rem;
    margin-top: 0.5rem;
  }
  .callout-body :global(li) {
    margin-top: 0.35rem;
  }
  .callout-body :global(strong) {
    color: #ffffff;
  }
</style>
